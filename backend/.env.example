# Database
DATABASE_URL="postgresql://user:password@localhost:5432/attanalpro?schema=public"

# JWT — har bir kalit kamida 32 ta belgi, BIR-BIRIDAN FARQLI va tasodifiy bo'lishi shart.
# Yangi kalit: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Diqqat: namunaviy qiymatlar bilan server productionda ishga tushmaydi.
JWT_SECRET="CHANGE_ME_min_32_random_chars________________"
JWT_REFRESH_SECRET="CHANGE_ME_different_32_random_chars__________"
# Ixtiyoriy: parol tiklash uchun alohida secret (berilmasa JWT_SECRET dan hosil qilinadi).
JWT_RESET_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# OpenAI
OPENAI_API_KEY="sk-..."

# AWS S3 (or DigitalOcean Spaces)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="attanalpro-uploads"

# Click (Uzbekistan payment)
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
CLICK_MERCHANT_USER_ID=""

# App URLs
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3000"

# Email (SMTP) – parol tiklash va obuna eslatmasi uchun
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS=""
SMTP_FROM="AttanalPro <noreply@example.com>"

# Optional: Node env
NODE_ENV="development"

# Faqat dev: tekin "simulyatsiya" to'lov endpointlarini productionda yoqish (tavsiya etilmaydi)
ALLOW_SIMULATED_PAYMENTS="false"
